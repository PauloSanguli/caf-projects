# Copie para .env e preencha (nunca commite .env com segredos).

# Django
# DJANGO_SECRET_KEY=
# DJANGO_DEBUG=True
# PRODUCTION=False
# DJANGO_ALLOWED_HOSTS=outro-dominio.com

# Supabase — PostgreSQL (Dashboard → Connect → URI; usar pooler ou direct conforme o projecto)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require

# Supabase — Storage S3 (Dashboard → Storage → S3 access keys)
# Crie um bucket (ex.: submissions) antes de subir ficheiros.
# SUPABASE_S3_ACCESS_KEY_ID=
# SUPABASE_S3_SECRET_ACCESS_KEY=
# SUPABASE_STORAGE_BUCKET=submissions
# Endpoint directo (recomendado para uploads grandes):
# SUPABASE_S3_ENDPOINT=https://SEU_PROJECT_REF.storage.supabase.co/storage/v1/s3
# SUPABASE_S3_REGION=eu-central-1
# Não defina AWS_S3_CUSTOM_DOMAIN com o host do Supabase: o django-storages passaria
# a emitir links sem assinatura e o Storage privado devolve Missing signature.

# Se não definir SUPABASE_*, os ficheiros ficam em media/ local (SQLite também).
